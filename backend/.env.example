# LLM API 配置
# 支持 OpenAI 兼容接口（包括 Anthropic、本地 LLM 等）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# 服务端口
SERVER_PORT=8000

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI 速率限制（每小时允许的最大请求数）
AI_RATE_LIMIT=30
AI_RATE_WINDOW_SEC=3600

# 数据存储路径（默认：backend/data/storage.json）
DB_PATH=