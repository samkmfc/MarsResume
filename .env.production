# ── 火星简历 · 生产环境变量 ────────────────────────────────
# 复制此文件为 .env 并修改配置
# cp .env.production .env && nano .env

# LLM API 配置（必填 — 替换为你的 API Key）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# CORS 允许的来源（生产环境只需填前端地址）
CORS_ORIGINS=http://your-server-ip

# 速率限制
AI_RATE_LIMIT=30
AI_RATE_WINDOW_SEC=3600